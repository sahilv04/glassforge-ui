{
  "name": "@glassforge/ui",
  "version": "0.0.1",
  "description": "Themeable React UI blocks for modern dashboards, SaaS apps, and portfolios. Start with glass. Customize everything.",
  "keywords": [
    "react",
    "ui",
    "components",
    "tailwind",
    "glassmorphism",
    "dashboard",
    "saas",
    "portfolio",
    "themeable",
    "design-system"
  ],
  "license": "MIT",
  "author": "GlassForge UI contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/sahilv04/glassforge-ui",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/sahilv04/glassforge-ui#readme",
  "bugs": {
    "url": "https://github.com/sahilv04/glassforge-ui/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./styles.css": "./dist/styles.css",
    "./themes/glass.css": "./dist/themes/glass.css",
    "./themes/solid.css": "./dist/themes/solid.css",
    "./themes/soft.css": "./dist/themes/soft.css",
    "./themes/midnight.css": "./dist/themes/midnight.css",
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm build:js && pnpm build:css",
    "build:js": "tsup",
    "build:css": "tailwindcss -i ./src/styles/index.css -o ./dist/styles.css --minify && node ./scripts/copy-themes.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "motion": "^11.11.17",
    "tailwind-merge": "^2.5.4"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.4.4",
    "@storybook/addon-themes": "^8.4.4",
    "@storybook/react": "^8.4.4",
    "@storybook/react-vite": "^8.4.4",
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@vitejs/plugin-react": "^4.3.3",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.4.4",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.3.5",
    "vite": "^5.4.10",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
